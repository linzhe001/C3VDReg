# Python/runtime cache
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# Local editor/OS files
.DS_Store
*.swp

# Local-only raw datasets and scratch outputs
data/
datasets/
raw_data/
tmp/
temp/
scripts/pcl_gen/tmp*

# External baseline source trees are cloned by the user and kept out of this repo.
/baselines/*
!/baselines/README.md
/forks/PointNetLK_c3vd/

# Runtime outputs are local-only. Keep only YAML config snapshots under outputs/.
/outputs/**/*
!/outputs/**/
!/outputs/**/*.yaml
!/outputs/**/*.yml

# Manuscript drafts and generated paper artifacts are local-only.
/BMVC2026_Linzhe/

# Checkpoints are distributed out-of-band and restored under checkpoints/.
/checkpoints/*
!/checkpoints/README.md
*.ckpt
*.pt
*.pth
*.pth.tar

# Environment-local files
.env
.venv/
venv/
