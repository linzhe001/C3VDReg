# Python/runtime cache
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# Local editor/OS files
.DS_Store
*.swp

# Keep project documentation centralized in the root README.md.
*.md
!/README.md
!/src/benchmarking/hparam_transfer/SKILL.md
/SELECTED_CHECKPOINTS.csv

# Local-only raw datasets and scratch outputs
/data/
/datasets/
/raw_data/
/tmp/
/temp/

# External baseline source trees are cloned by the user and kept out of this repo.
/baselines/*
/forks/PointNetLK_c3vd/

# Runtime outputs are local-only.
/outputs/

# Manuscript drafts and generated paper artifacts are local-only.
/BMVC2026_Linzhe/

# Checkpoints are distributed out-of-band except the committed GeoTransformer
# tiny smoke-test checkpoint shards. The runnable .pth is reassembled locally.
/checkpoints/*
!/checkpoints/geotransformer/
!/checkpoints/geotransformer/geotransformer_c3vd_model_best.pth.parts/
!/checkpoints/geotransformer/geotransformer_c3vd_model_best.pth.parts/*
*.ckpt
*.pt
*.pth
*.pth.tar

# Environment-local files
.env
.venv/
venv/
